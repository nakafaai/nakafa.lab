{
  "name": "nakafa.lab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "check": "python3 scripts/check_repo.py",
    "check:uv": "uv run python scripts/check_repo.py",
    "format:py": "uv run ruff format .",
    "lint:py": "uv run ruff check .",
    "paper:build": "mkdir -p paper/build && tectonic --synctex --keep-logs --outdir paper/build paper/main.tex",
    "paper:open": "open paper/build/main.pdf"
  }
}
